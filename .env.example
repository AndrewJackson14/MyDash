# 13 Stars Media PubHub — Environment Variables
# Copy this to .env and fill in your values

# Supabase (required for database + auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth (configured in Supabase dashboard, not here)
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: https://YOUR_PROJECT.supabase.co/auth/v1/callback
# 4. Go to Supabase Dashboard → Authentication → Providers → Google
# 5. Enter your Google Client ID and Secret

# Google API (for Gmail/Calendar — configured via Supabase Edge Functions)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
