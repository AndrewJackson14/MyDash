    {
      "id": "ad-lifecycle",
      "name": "Ad sale → contract → ad project → proof → flatplan → press → invoice",
      "owners_in_order": ["sales-rep", "ad-designer", "sales-rep", "ad-designer", "layout-designer", "publisher", "office-admin"],
      "key_rpcs": ["convert_proposal_to_contract", "ad_projects (created on sale closed)", "send-proof", "send-to-press", "insertInvoice"]
    },
    {
      "id": "editorial-flow",
      "name": "Pitch → assign → draft → edit → approve-for-web → publish → place-on-page → press",
      "owners_in_order": ["editor-in-chief", "content-editor", "writer-reporter", "content-editor", "editor-in-chief", "content-editor", "layout-designer", "publisher"],
      "key_rpcs": ["publishStory (sets sent_to_web=true, published_at)", "unpublishStory", "page_stories", "send-to-press"]
    },
    {
      "id": "issue-press-readiness",
      "name": "Issue layout complete → publisher signoff → send-to-press → tearsheet generation",
      "owners_in_order": ["layout-designer", "publisher", "layout-designer", "office-admin"],
      "key_rpcs": ["UPDATE issues SET publisher_signoff_at, publisher_signoff_by", "send-to-press Edge Function", "generate-tearsheets"]
    },
    {
      "id": "ar-cycle",
      "name": "Invoice mint → send → payment → reconcile → QBO sync → commission ledger",
      "owners_in_order": ["sales-rep", "office-admin", "office-admin", "office-admin", "publisher"],
      "key_rpcs": ["insertInvoice", "send-statement", "stripe-webhook", "qb-api", "commissions recalculate"]
    },
    {
      "id": "subscription-renewal",
      "name": "Subscriber expiry approaching → renewal email cadence → payment → end_date roll-forward",
      "owners_in_order": ["office-admin"],
      "key_rpcs": ["renewal email send (Gmail)", "subscription_payments insert", "stripe-webhook (for auto-renew)"]
    }
  ],
