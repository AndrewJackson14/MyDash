# Press Release Processor — .env template
#
# Copy this file to .env (in the same folder) and fill in the real
# values. .env is gitignored; .env.example is committed.
#
# On the Mac Mini deployment, this lives at:
#   /Users/wednesdayagentic/wednesday-station/jobs/press-processor/.env

# ─── Supabase (same across all agents) ─────────────────
SUPABASE_URL=https://hqywacyhpllapdwccmaw.supabase.co
SUPABASE_SERVICE_KEY=eyJ...paste-from-supabase-dashboard...

# ─── Gemini (same across all agents) ───────────────────
GEMINI_API_KEY=AIza...paste-from-google-ai-studio...
GEMINI_MODEL=gemini-2.5-flash

# ─── Bot identity (from migration 088) ─────────────────
PRESS_BOT_ID=a1111111-0000-0000-0000-000000000001

# ─── Gmail OAuth ───────────────────────────────────────
# Path to OAuth credentials downloaded from Google Cloud Console.
# Create via: APIs & Services → Credentials → Create Credentials →
# OAuth client ID → Desktop app. Download JSON.
GMAIL_OAUTH_CREDENTIALS_PATH=/Users/wednesdayagentic/wednesday-station/jobs/press-processor/credentials.json

# Where to save/read the OAuth token. Created on first run when the
# bot opens a browser for user consent. Never commit this file.
GMAIL_OAUTH_TOKEN_PATH=/Users/wednesdayagentic/wednesday-station/jobs/press-processor/token.json

# ─── Drive intake folder ───────────────────────────────
# The Drive folder where staff drop PDFs/DOCXs. Get the ID from the
# URL: https://drive.google.com/drive/folders/{FOLDER_ID}
DRIVE_INTAKE_FOLDER_ID=

# Sibling "Processed" subfolder where the bot moves handled files.
# Same method: open the folder, grab the ID from the URL.
DRIVE_PROCESSED_FOLDER_ID=

# ─── Polling ───────────────────────────────────────────
# Seconds between poll cycles. 60 is fine — press releases aren't urgent.
POLL_INTERVAL=60
