# Editorial Assistant — environment template.
#
# Copy to `.env` on the Mac Mini and fill in real values. The plist
# does NOT load .env automatically; either source it from the shell
# launchd inherits, or wrap server.py in a launcher that loads it.
# (myhelper / press-processor solve this by importing python-dotenv
# at the top of bot.py.)

# Shared bearer token. Set the SAME value in the Supabase Edge
# Function `editorial_check` so it can authenticate forwards. Generate
# with: openssl rand -hex 32
MYDASH_TOKEN=

# Port FastAPI binds on the Mac Mini. Default is 8765.
EDITORIAL_PORT=8765

# Override the default GitHub raw base if you're testing against a
# different branch / fork. Leave unset for production.
# KB_BASE=https://raw.githubusercontent.com/AndrewJackson14/MyDash/main/docs/knowledge-base

# On-disk voice-profile cache. Default ~/.cache/wed-agents/voice-kb.
# VOICE_CACHE_DIR=

# TTL in seconds. Default 3600 (1 hour).
# VOICE_CACHE_TTL=

# Phase C — Gemini API key. Empty in Phase B, the skills aren't shipped.
# GEMINI_API_KEY=

# Phase C — model id. Locked at 2.0 Flash for latency; bump if needed.
# GEMINI_MODEL=gemini-2.0-flash
